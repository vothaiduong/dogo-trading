# Local development env for docker-compose. Copy to `.env` and edit as needed.

# --- Database ---
DB_NAME=dogo
DB_USER=dogo
DB_PASSWORD=dogopw
DB_ROOT_PASSWORD=rootpw

# --- WordPress site ---
WP_PORT=8080
PMA_PORT=8081
WP_URL=http://localhost:8080
WP_TITLE=Dogo Corporation
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@example.com

# --- Production deploy (used by deploy/deploy.sh) ---
# Vultr VPS public IP or hostname:
PROD_HOST=
PROD_SSH_USER=root
PROD_SSH_PORT=22
PROD_DOMAIN=dogo-corporation.example.com
PROD_LE_EMAIL=admin@example.com
PROD_DB_NAME=dogo_prod
PROD_DB_USER=dogo_prod
PROD_DB_PASSWORD=
